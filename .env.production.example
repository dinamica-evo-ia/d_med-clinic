APP_NAME=MedHealth
APP_ENV=production
APP_DEBUG=false
APP_URL=https://www.dmedclinic.com.br

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=dmedclinic
# DB_USERNAME=dmedclinic
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=.dmedclinic.com.br

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@dmedclinic.com.br"
MAIL_FROM_NAME="${APP_NAME}"

AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini

DMED_INTEGRACAO_SECRET=your-secret-here
DMED_STUDIO_URL=https://app.dmedevo.com.br

## If using MySQL instead of SQLite, uncomment and set these:
# DB_HOST=mysql
# DB_PORT=3306
# DB_DATABASE=dmedclinic
# DB_USERNAME=dmedclinic
# DB_PASSWORD=
